generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ItemStatus {
  new
  fetched
  filtered
  processed
  failed
}

enum ModerationStatus {
  allowed
  filtered
  restored
}

enum ModerationReason {
  marketing
  low_quality
  duplicate_noise
  rule_filter
  rule_blacklist
  other
}

enum ProcessingCheckpointStatus {
  pending
  succeeded
  failed
}

enum FetchRunStatus {
  running
  succeeded
  failed
  partial
}

enum IngestionTrigger {
  scheduled
  manual
}

enum BackgroundTaskKind {
  ingestion
  item_regenerate_translation
  item_regenerate_summary
  item_reanalyze
  cluster_regenerate_summary
  daily_report_generate
  item_cleanup
  item_reparse_aggregations
}

enum BackgroundTaskTrigger {
  scheduled
  manual
  admin_action
}

enum BackgroundTaskStatus {
  queued
  running
  succeeded
  failed
  partial
  cancelled
}

enum ContentClusterKind {
  topic
}

enum ContentClusterStatus {
  active
  hidden
}

enum PromptConfigType {
  item_summary
  item_analysis
  item_aggregation
  cluster_summary
  cluster_match
  cluster_merge
  daily_report
}

enum DailyReportStatus {
  draft
  published
  failed
}

model Source {
  id                          String       @id @default(cuid())
  groupId                     String?
  name                        String
  rssUrl                      String       @unique
  siteUrl                     String
  enabled                     Boolean      @default(true)
  aiParsingEnabled            Boolean      @default(true)
  aggregationEnabled          Boolean      @default(true)
  aggregationDetectionEnabled Boolean      @default(false)
  feedEtag                    String?
  feedLastModified            String?
  feedContentHash             String?
  lastFetchedAt               DateTime?
  healthStatus                String       @default("unknown")
  healthMessage               String?
  healthCheckedAt             DateTime?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt
  items                       Item[]
  group                       SourceGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([groupId, name])
  @@index([enabled, healthStatus])
  @@map("sources")
}

model Item {
  id                       String                     @id @default(cuid())
  sourceId                 String
  clusterId                String?
  originalUrl              String
  canonicalUrl             String
  urlHash                  String                     @unique
  dedupeSignature          String                     @unique
  originalTitle            String
  translatedTitle          String?
  author                   String?
  publishedAt              DateTime
  rssExcerpt               String?
  rssContent               String?
  fullText                 String?
  summaryText              String?
  language                 String?
  status                   ItemStatus                 @default(new)
  summaryStatus            ProcessingCheckpointStatus @default(pending)
  analysisStatus           ProcessingCheckpointStatus @default(pending)
  filterReason             String?
  moderationStatus         ModerationStatus           @default(allowed)
  moderationReason         ModerationReason?
  moderationDetail         String?
  qualityScore             Int                        @default(50)
  qualityRationale         String                     @default("AI analysis unavailable")
  eventType                String?
  eventSubject             String?
  eventAction              String?
  eventObject              String?
  eventDate                String?
  aiProcessedAt            DateTime?
  manualClusterAssignedAt  DateTime?
  restoredByAdminAt        DateTime?
  isAggregation            Boolean                    @default(false)
  aggregationCheckedAt     DateTime?
  aggregationParseStatus   String?
  parentItemId             String?
  errorMessage             String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  source                   Source                     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  cluster                  ContentCluster?            @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  parent                   Item?                      @relation("ItemChildren", fields: [parentItemId], references: [id], onDelete: SetNull)
  children                 Item[]                     @relation("ItemChildren")
  aggregationSplitParents  AggregationSplitLink[]     @relation("AggregationSplitChild")
  aggregationSplitChildren AggregationSplitLink[]     @relation("AggregationSplitParent")
  dailyReportSources       DailyReportSource[]
  tags                     ItemTag[]

  @@index([sourceId, publishedAt])
  @@index([sourceId, status, moderationStatus, isAggregation, createdAt])
  @@index([status, publishedAt])
  @@index([moderationStatus, publishedAt])
  @@index([status, moderationStatus, createdAt])
  @@index([status, moderationStatus, updatedAt])
  @@index([clusterId, publishedAt])
  @@index([clusterId, status, moderationStatus, updatedAt])
  @@index([qualityScore, publishedAt])
  @@index([parentItemId])
  @@map("items")
}

model AggregationSplitLink {
  id           String   @id @default(cuid())
  parentItemId String
  childItemId  String
  eventIndex   Int
  fingerprint  String
  title        String?
  oneLiner     String
  sourceUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  parent       Item     @relation("AggregationSplitParent", fields: [parentItemId], references: [id], onDelete: Cascade)
  child        Item     @relation("AggregationSplitChild", fields: [childItemId], references: [id], onDelete: Cascade)

  @@unique([parentItemId, eventIndex])
  @@index([childItemId])
  @@index([parentItemId, fingerprint])
  @@index([parentItemId, createdAt])
  @@map("aggregation_split_links")
}

model ContentCluster {
  id                    String               @id @default(cuid())
  kind                  ContentClusterKind   @default(topic)
  title                 String
  summary               String
  summaryInputHash      String?
  mergeInputHash        String?
  score                 Int                  @default(50)
  itemCount             Int                  @default(0)
  latestPublishedAt     DateTime
  status                ContentClusterStatus @default(active)
  fingerprint           String               @unique
  eventType             String?
  eventSubject          String?
  eventAction           String?
  eventObject           String?
  eventDate             String?
  displayItemCount      Int                  @default(0)
  displaySourceCount    Int                  @default(0)
  displayAverageScore   Int                  @default(0)
  displayRecommendScore Int                  @default(0)
  latestCreatedAt       DateTime?
  dominantGroupId       String?
  feedSearchText        String?
  feedTagsJson          String               @default("[]")
  feedStatsUpdatedAt    DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  items                 Item[]
  dailyReportSources    DailyReportSource[]
  dominantGroup         SourceGroup?         @relation(fields: [dominantGroupId], references: [id], onDelete: SetNull)

  @@index([status, latestPublishedAt])
  @@index([status, latestCreatedAt])
  @@index([status, displayRecommendScore])
  @@index([dominantGroupId, status, latestCreatedAt])
  @@map("content_clusters")
}

model FetchRun {
  id           String             @id @default(cuid())
  taskRunId    String?
  triggerType  IngestionTrigger
  status       FetchRunStatus     @default(running)
  startedAt    DateTime           @default(now())
  finishedAt   DateTime?
  sourceCount  Int                @default(0)
  itemCount    Int                @default(0)
  successCount Int                @default(0)
  failureCount Int                @default(0)
  itemsAdded   Int                @default(0)
  errorSummary String?
  taskRun      BackgroundTaskRun? @relation(fields: [taskRunId], references: [id], onDelete: SetNull)

  @@index([taskRunId])
  @@index([startedAt])
  @@map("fetch_runs")
}

model TaskSchedule {
  id                        String                @id @default(cuid())
  key                       String                @unique
  enabled                   Boolean               @default(false)
  cronExpression            String                @default("0 * * * *")
  sourceConcurrency         Int                   @default(2)
  fullTextFetchThreshold    Int                   @default(80)
  perSourceItemLimit        Int                   @default(20)
  aggregationSplitMaxEvents Int                   @default(20)
  dailyReportCandidateLimit Int                   @default(120)
  dailyReportOffsetDays     Int                   @default(0)
  dailyReportAutoPublish    Boolean               @default(false)
  dailyReportMaxRetries     Int                   @default(0)
  dailyReportGroupIdsJson   String                @default("")
  cleanupRetentionDays      Int                   @default(365)
  processingStartAt         DateTime?
  timezone                  String
  lastHeartbeatAt           DateTime?
  lastRunStartedAt          DateTime?
  lastRunFinishedAt         DateTime?
  lastRunStatus             BackgroundTaskStatus?
  nextRunAt                 DateTime
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt

  @@map("task_schedules")
}

model ContentExtractionConfig {
  id          String   @id @default(cuid())
  jinaEnabled Boolean  @default(false)
  jinaBaseUrl String   @default("https://r.jina.ai/")
  jinaApiKey  String?
  timeoutMs   Int      @default(15000)
  concurrency Int      @default(1)
  rpmLimit    Int      @default(10)
  maxPerRun   Int      @default(20)
  minChars    Int      @default(500)
  maxChars    Int      @default(32000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("content_extraction_configs")
}

model BackgroundTaskRun {
  id                   String                @id @default(cuid())
  kind                 BackgroundTaskKind
  triggerType          BackgroundTaskTrigger
  status               BackgroundTaskStatus  @default(queued)
  label                String
  entityId             String?
  progressCurrent      Int                   @default(0)
  progressTotal        Int                   @default(0)
  progressLabel        String?
  itemsAdded           Int                   @default(0)
  fullTextFetchedCount Int                   @default(0)
  aiCallCountActual    Int                   @default(0)
  aiCallCountEstimated Int                   @default(0)
  aiCallBreakdownJson  String?
  cancelRequestedAt    DateTime?
  startedAt            DateTime?
  finishedAt           DateTime?
  errorSummary         String?
  stageTimingsJson     String?
  taskTimelineJson     String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  fetchRuns            FetchRun[]
  dailyReports         DailyReport[]

  @@index([status, createdAt])
  @@index([kind, status, createdAt])
  @@map("background_task_runs")
}

model DailyReport {
  id                String              @id @default(cuid())
  date              String
  timezone          String              @default("Asia/Shanghai")
  status            DailyReportStatus   @default(draft)
  title             String
  openingSummary    String
  closingThought    String
  summaryJson       String
  renderedMarkdown  String
  inputHash         String
  modelName         String?
  taskRunId         String?
  candidateSnapshot String?
  errorMessage      String?
  publishedAt       DateTime?
  generatedAt       DateTime            @default(now())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  taskRun           BackgroundTaskRun?  @relation(fields: [taskRunId], references: [id], onDelete: SetNull)
  sources           DailyReportSource[]

  @@unique([date, timezone])
  @@index([status, date])
  @@index([taskRunId])
  @@map("daily_reports")
}

model DailyReportSource {
  id                 String          @id @default(cuid())
  dailyReportId      String
  sourceNumber       Int?
  sourceKey          String?
  itemId             String?
  clusterId          String?
  sourceName         String
  title              String
  url                String
  sourceSummary      String?
  sourcePublishedAt  DateTime?
  sourceQualityScore Int?
  eventType          String?
  eventSubject       String?
  eventAction        String?
  eventObject        String?
  eventDate          String?
  sectionName        String?
  topic              String?
  createdAt          DateTime        @default(now())
  dailyReport        DailyReport     @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
  item               Item?           @relation(fields: [itemId], references: [id], onDelete: SetNull)
  cluster            ContentCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)

  @@index([dailyReportId])
  @@index([dailyReportId, sourceNumber])
  @@index([dailyReportId, sourceKey])
  @@index([itemId])
  @@index([clusterId])
  @@map("daily_report_sources")
}

model Tag {
  id         String    @id @default(cuid())
  name       String
  normalized String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  items      ItemTag[]

  @@index([name])
  @@map("tags")
}

model ItemTag {
  id        String   @id @default(cuid())
  itemId    String
  tagId     String
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([itemId, tagId])
  @@index([tagId])
  @@index([itemId])
  @@map("item_tags")
}

model SourceGroup {
  id               String           @id @default(cuid())
  name             String           @unique
  color            String           @default("")
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sources          Source[]
  dominantClusters ContentCluster[]

  @@index([sortOrder, name])
  @@map("source_groups")
}

model ModelApiConfig {
  id                       String         @id @default(cuid())
  name                     String
  baseUrl                  String
  apiKey                   String         @default("")
  modelName                String
  ingestionItemConcurrency Int            @default(3)
  customHeaders            String         @default("")
  isEnabled                Boolean        @default(true)
  isDefault                Boolean        @default(false)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  promptConfigs            PromptConfig[]

  @@index([isEnabled, isDefault])
  @@map("model_api_configs")
}

model PromptConfig {
  id               String           @id @default(cuid())
  name             String
  type             PromptConfigType
  prompt           String
  systemPrompt     String?
  templateJson     String?
  temperature      Float?
  maxTokens        Int?
  topP             Float?
  modelApiConfigId String?
  isEnabled        Boolean          @default(true)
  isDefault        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  modelApiConfig   ModelApiConfig?  @relation(fields: [modelApiConfigId], references: [id], onDelete: SetNull)

  @@index([type, isEnabled, isDefault])
  @@index([modelApiConfigId])
  @@map("prompt_configs")
}

model SourceHealthLog {
  id         String   @id @default(cuid())
  sourceId   String
  sourceName String
  fromStatus String
  toStatus   String
  message    String?
  changedAt  DateTime @default(now())

  @@index([sourceId, changedAt])
  @@index([changedAt])
  @@map("source_health_logs")
}

model BlacklistKeyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blacklist_keywords")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  visitorId String
  date      String
  createdAt DateTime @default(now())

  @@index([path, date])
  @@index([path, date, visitorId])
  @@index([path, visitorId])
  @@map("page_views")
}
