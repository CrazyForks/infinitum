DATABASE_URL="file:./prisma/dev.db"
# Optional: canonical public site origin used for RSS links behind reverse proxies.
# SITE_URL="https://your-domain.example"

# Optional: override worker -> app cache warm origin. Docker compose defaults to http://app:3000.
# FEED_CACHE_WARM_URL="http://localhost:3000"
# Optional: Docker Compose worker CPU quota. Compose reads this from .env or shell, not .env.docker.
# WORKER_CPUS="0.50"
# Optional: outbound proxy for RSS/article/model API requests made by Node fetch.
# HTTP_PROXY="http://127.0.0.1:7890"
# HTTPS_PROXY="http://127.0.0.1:7890"
# NO_PROXY="localhost,127.0.0.1,::1"
ADMIN_PASSWORD="change-me"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"
