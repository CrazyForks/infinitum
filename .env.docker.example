DATABASE_URL=file:/app/data/dev.db
# Optional: canonical public site origin used for RSS links behind reverse proxies.
# SITE_URL=https://your-domain.example

# Optional: override worker -> app cache warm origin. Defaults to http://app:3000.
# FEED_CACHE_WARM_URL=http://app:3000
# Optional: outbound proxy for RSS/article/model API requests made by Node fetch.
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890
# NO_PROXY=localhost,127.0.0.1,::1,app
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_SESSION_COOKIE_SECURE=true
