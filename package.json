{
  "name": "infinitum",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "node scripts/build-worker.mjs",
    "start": "next start",
    "worker": "tsx scripts/run-worker.ts",
    "lint": "eslint .",
    "db:setup": "node scripts/setup-sqlite.mjs prisma/dev.db && npm run prisma:generate && tsx scripts/seed-defaults.ts",
    "db:test:setup": "node scripts/setup-sqlite.mjs prisma/test.db --reset && npm run prisma:generate && DATABASE_URL=\"file:./prisma/test.db\" tsx scripts/seed-defaults.ts",
    "test": "npm run prisma:generate && npm run db:test:setup && vitest run --coverage",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^6.16.1",
    "antd": "^5.29.3",
    "cron-parser": "^5.5.0",
    "dayjs": "^1.11.19",
    "jsdom": "^29.0.2",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.27.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5.10",
    "prisma": "^6.16.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
