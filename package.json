{
  "name": "infinitum",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "worker": "tsx scripts/run-worker.ts",
    "lint": "eslint .",
    "db:setup": "node scripts/setup-sqlite.mjs prisma/dev.db",
    "db:test:setup": "node scripts/setup-sqlite.mjs prisma/test.db --reset",
    "test": "npm run prisma:generate && npm run db:test:setup && vitest run --coverage",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^6.16.1",
    "dotenv": "^17.4.1",
    "jsdom": "^29.0.2",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rss-parser": "^3.13.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^6.16.1",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
